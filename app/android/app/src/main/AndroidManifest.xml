<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml  —  Permisos BLE requeridos para Android
  ─────────────────────────────────────────────────────────────
  Android 12+ usa BLUETOOTH_SCAN y BLUETOOTH_CONNECT.
  Android 6-11 usa ACCESS_FINE_LOCATION para el escaneo BLE.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permisos Bluetooth (Android 12+) ──────────────── -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- ── Permisos Bluetooth (Android 6-11) ─────────────── -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- ── Feature BLE ───────────────────────────────────── -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <!-- ── Internet (no requerido, pero por si usas OTA) ─── -->
    <!-- <uses-permission android:name="android.permission.INTERNET" /> -->

    <application
        android:label="Bípedo 8-DOF"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- No se necesita FlutterEmbeddingV2 explícito en Flutter 3+ -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- namespace xmlns:tools para targetApi en permisos -->
    <uses-permission
        android:name="android.permission.CHANGE_NETWORK_STATE"
        tools:node="remove" />
</manifest>
